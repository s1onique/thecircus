{
  "name": "circus-web",
  "version": "0.1.0",
  "description": "The Circus Elm frontend",
  "private": true,
  "scripts": {
    "format": "elm-format src --yes",
    "format:check": "elm-format src --validate",
    "test": "elm-test",
    "build": "elm make src/Main.elm --optimize --output=dist/app.js",
    "build:dev": "elm make src/Main.elm --output=dist/app.js",
    "clean": "rm -rf dist elm-stuff"
  },
  "devDependencies": {
    "elm": "0.19.2-0",
    "elm-format": "0.8.7",
    "elm-test": "0.19.2-0"
  }
}
