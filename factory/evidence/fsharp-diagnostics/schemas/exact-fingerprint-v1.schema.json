{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://circus.local/schemas/fsharp-diagnostics/exact-fingerprint-v1.schema.json",
  "title": "F# exact fingerprint (v1)",
  "description": "One exact-fingerprint entry.  Wire representation of an ExactFingerprint is the TSV row, not JSON; this schema is for documentation and unit tests.",
  "type": "object",
  "required": [
    "fingerprint_version",
    "severity",
    "sha256",
    "message_normalized",
    "occurrence_count"
  ],
  "additionalProperties": false,
  "properties": {
    "fingerprint_version": { "type": "string", "const": "exact-fingerprint-v1" },
    "severity": { "type": "string", "enum": ["warning", "error"] },
    "subcategory": { "type": ["string", "null"] },
    "code": { "type": ["string", "null"] },
    "source_path": { "type": ["string", "null"] },
    "project_path": { "type": ["string", "null"] },
    "start_line": { "type": ["integer", "null"] },
    "start_column": { "type": ["integer", "null"] },
    "end_line": { "type": ["integer", "null"] },
    "end_column": { "type": ["integer", "null"] },
    "message_normalized": { "type": "string" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "occurrence_count": { "type": "integer", "minimum": 1 }
  }
}