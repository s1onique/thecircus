    <Compile Include="IngestionAuthorization.fs" />
    <Compile Include="IngestEvent.fs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Circus.Domain\Circus.Domain.fsproj" />
    <ProjectReference Include="..\Circus.Contracts\Circus.Contracts.fsproj" />
  </ItemGroup>
</Project>
